{
  "name": "stocks-crawler",
  "version": "1.1.1",
  "description": "Minimal TypeScript library to fetch stock quotes from Boursorama",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BastienBoymond/stocks-crawler.git"
  },
  "bugs": {
    "url": "https://github.com/BastienBoymond/stocks-crawler/issues"
  },
  "homepage": "https://github.com/BastienBoymond/stocks-crawler#readme",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "example": "tsx src/example.ts"
  },
  "devDependencies": {
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  },
  "keywords": [
    "stocks",
    "boursorama",
    "crawler",
    "finance",
    "etf",
    "tracker",
    "euronext",
    "isin"
  ],
  "license": "MIT"
}
